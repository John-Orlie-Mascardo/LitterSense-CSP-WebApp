rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /deviceConfigs/{configToken} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to read and write their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /cats/{catId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /catDetails/{catId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Real-time visit/session history generated by RFID scans:
      // users/{uid}/sessions/{sessionId}
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Per-cat health notes entered from the Health Log tab:
      // users/{uid}/healthLogs/{logId}
      match /healthLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // User notification feed entries:
      // users/{uid}/notifications/{notificationId}
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /deviceConfig/{configId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Fast current-day summary per cat:
      // users/{uid}/catStats/{catId}
      match /catStats/{catId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Date-organized history per cat:
        // users/{uid}/catStats/{catId}/daily/{YYYY-MM-DD}
        match /daily/{date} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // Date-first dashboard history:
      // users/{uid}/dailyCatStats/{YYYY-MM-DD}/cats/{catId}
      match /dailyCatStats/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;

        match /cats/{catId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }
  }
}
