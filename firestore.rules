rules_version = '2';

/**
 * LitterSense Firestore Security Rules
 * 
 * HARD DELETE POLICY (Option 1):
 * When a user requests account deletion and an admin approves:
 * 1. All user data (cats, health logs, sessions, notifications, etc.) is permanently deleted from Firestore
 * 2. All associated Cloud Storage files are deleted
 * 3. The user's Firebase Auth account is marked for deletion
 * 
 * Admin deletion is restricted to: maclaurenz.cultura@gmail.com
 * 
 * SECURITY NOTE:
 * In production, account deletion should be handled by a Cloud Function (backend)
 * rather than client-side Firestore operations. This ensures:
 * - Proper audit logging
 * - Cascading deletion of all related data
 * - Protection against unauthorized deletions
 * 
 * For now, admin email is hardcoded. Update before production deployment.
 */

service cloud.firestore {
  match /databases/{database}/documents {
    match /deviceConfigs/{configToken} {
      allow get: if true;
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    match /rules/{ruleId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
    }

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow users to read and write their own user document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow admin to delete user data during account deletion
      allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";

      match /cats/{catId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
      }

      match /catDetails/{catId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
      }

      // Real-time visit/session history generated by RFID scans:
      // users/{uid}/sessions/{sessionId}
      match /sessions/{sessionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
      }

      // Per-cat health notes entered from the Health Log tab:
      // users/{uid}/healthLogs/{logId}
      match /healthLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
      }

      // User notification feed entries:
      // users/{uid}/notifications/{notificationId}
      match /notifications/{notificationId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
      }

      match /deviceConfig/{configId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
      }

      // Fast current-day summary per cat:
      // users/{uid}/catStats/{catId}
      match /catStats/{catId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";

        // Date-organized history per cat:
        // users/{uid}/catStats/{catId}/daily/{YYYY-MM-DD}
        match /daily/{date} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
          allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
        }
      }

      // Date-first dashboard history:
      // users/{uid}/dailyCatStats/{YYYY-MM-DD}/cats/{catId}
      match /dailyCatStats/{date} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";

        match /cats/{catId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
          allow delete: if request.auth != null && request.auth.token.email == "maclaurenz.cultura@gmail.com";
        }
      }
    }
  }
}
